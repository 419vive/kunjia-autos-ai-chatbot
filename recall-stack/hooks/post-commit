#!/bin/bash
# Logs every commit to .claude-memory.md in the repo root
# Copy to .git/hooks/post-commit in any repo you want tracked

DATE=$(date '+%Y-%m-%d %H:%M:%S')
MSG=$(git log -1 --pretty=%B)
BRANCH=$(git branch --show-current)

echo "[$DATE] [$BRANCH] $MSG" >> "$(git rev-parse --show-toplevel)/.claude-memory.md"
