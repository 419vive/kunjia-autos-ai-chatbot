{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "deepwiki": {
      "command": "npx",
      "args": ["-y", "deepwiki-mcp"]
    },
    "hindsight": {
      "command": "npx",
      "args": ["-y", "@vectorize-io/hindsight-mcp"],
      "env": {
        "HINDSIGHT_API_URL": "http://localhost:8888"
      }
    }
  }
}
