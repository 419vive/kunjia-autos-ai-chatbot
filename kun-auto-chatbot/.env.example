# === Required: Database ===
DATABASE_URL=mysql://user:password@127.0.0.1:3306/kun_auto_chatbot

# === Required: Google AI Gemini API (for chatbot LLM) ===
GOOGLE_AI_API_KEY=AIzaSy...

# === Required: LINE Bot ===
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# === Optional: LINE notifications ===
LINE_OWNER_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_ADDITIONAL_NOTIFY_USER_IDS=Uaaa,Ubbb

# === Optional: Rule-based mode (skip LLM, use pattern matching) ===
# Set to 1 to enable rule-based replies without calling Gemini API
# Useful when API key is not available or to save costs
FORCE_RULE_BASED_REPLY=1

# === Optional: Auth ===
JWT_SECRET=your_random_jwt_secret
